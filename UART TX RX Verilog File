`timescale 1ns/1ps

module uart_tx #(parameter CLKS_PER_BIT = 8)(
    input clk,
    input reset,
    input tx_start,
    input [7:0] data_in,
    output reg tx_serial,
    output reg tx_done
);

    reg [3:0] bit_index;
    reg [7:0] clk_count;
    reg [2:0] state;

    localparam IDLE  = 0;
    localparam START = 1;
    localparam DATA  = 2;
    localparam STOP  = 3;
    localparam DONE  = 4;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            state <= IDLE;
            tx_serial <= 1;
            tx_done <= 0;
            clk_count <= 0;
            bit_index <= 0;
        end else begin
            case (state)

                IDLE: begin
                    tx_serial <= 1;
                    tx_done <= 0;
                    if (tx_start) begin
                        state <= START;
                        clk_count <= 0;
                    end
                end

                START: begin
                    tx_serial <= 0;
                    if (clk_count < CLKS_PER_BIT-1)
                        clk_count <= clk_count + 1;
                    else begin
                        clk_count <= 0;
                        state <= DATA;
                        bit_index <= 0;
                    end
                end

                DATA: begin
                    tx_serial <= data_in[bit_index];
                    if (clk_count < CLKS_PER_BIT-1)
                        clk_count <= clk_count + 1;
                    else begin
                        clk_count <= 0;
                        if (bit_index < 7)
                            bit_index <= bit_index + 1;
                        else
                            state <= STOP;
                    end
                end

                STOP: begin
                    tx_serial <= 1;
                    if (clk_count < CLKS_PER_BIT-1)
                        clk_count <= clk_count + 1;
                    else begin
                        state <= DONE;
                        clk_count <= 0;
                    end
                end

                DONE: begin
                    tx_done <= 1;
                    state <= IDLE;
                end

            endcase
        end
    end

endmodule

module uart_rx #(parameter CLKS_PER_BIT = 8)(
    input clk,
    input reset,
    input rx_serial,
    output reg [7:0] data_out,
    output reg rx_done
);

    reg [3:0] bit_index;
    reg [7:0] clk_count;
    reg [2:0] state;

    localparam IDLE  = 0;
    localparam START = 1;
    localparam DATA  = 2;
    localparam STOP  = 3;
    localparam DONE  = 4;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            state <= IDLE;
            rx_done <= 0;
            clk_count <= 0;
            bit_index <= 0;
            data_out <= 0;   // 🔥 IMPORTANT FIX
        end else begin
            case (state)

                IDLE: begin
                    rx_done <= 0;
                    if (rx_serial == 0) begin
                        state <= START;
                        clk_count <= 0;
                    end
                end

                START: begin
                    // sample in middle of start bit
                    if (clk_count < (CLKS_PER_BIT/2))
                        clk_count <= clk_count + 1;
                    else begin
                        clk_count <= 0;
                        state <= DATA;
                        bit_index <= 0;
                    end
                end

                DATA: begin
                    if (clk_count < CLKS_PER_BIT-1)
                        clk_count <= clk_count + 1;
                    else begin
                        clk_count <= 0;
                        data_out[bit_index] <= rx_serial;
                        if (bit_index < 7)
                            bit_index <= bit_index + 1;
                        else
                            state <= STOP;
                    end
                end

                STOP: begin
                    if (clk_count < CLKS_PER_BIT-1)
                        clk_count <= clk_count + 1;
                    else begin
                        clk_count <= 0;
                        state <= DONE;
                    end
                end

                DONE: begin
                    rx_done <= 1;
                    state <= IDLE;
                end

            endcase
        end
    end

endmodule
